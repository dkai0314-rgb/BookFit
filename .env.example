# Database — Firebase Firestore (admin SDK 사용, FIREBASE_* env가 곧 DB 자격)
# (Prisma/Postgres는 Firestore로 마이그레이션됨 — DATABASE_URL/DIRECT_URL 사용 안 함)

# Anthropic Claude (BookFit AI 추천/큐레이션)
# https://console.anthropic.com/
ANTHROPIC_API_KEY="your_anthropic_api_key"

# Google Books API
GOOGLE_BOOKS_API_KEY="your_google_books_api_key"

# Aladin API
# https://www.aladin.co.kr/ttb/wttb_main.aspx
ALADIN_API_KEY="your_aladin_api_key"

# Brevo (Email Service)
BREVO_API_KEY=your_brevo_api_key
BREVO_BASE_URL=https://api.brevo.com/v3
BREVO_LIST_ID=7
# Brevo 발송용 sender (W4: bookfit-letter publish 시 자동 발송)
BREVO_SENDER_EMAIL=newsletter@bookfit.kr
BREVO_SENDER_NAME=BookFit

# Google Analytics 4 (W5)
NEXT_PUBLIC_GA_ID=

# Admin Basic Auth (proxy.ts에서 /admin/* 보호)
ADMIN_USER=admin
ADMIN_PASSWORD=

# Firebase Config (Client-side)
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id

# Firebase Admin (Server-side)
FIREBASE_PROJECT_ID=your_project_id
FIREBASE_CLIENT_EMAIL=your_client_email
FIREBASE_PRIVATE_KEY="your_private_key"

# Coupang Partners API
COUPANG_ACCESS_KEY=your_coupang_access_key
COUPANG_SECRET_KEY=your_coupang_secret_key

# Toss Payments
NEXT_PUBLIC_TOSS_CLIENT_KEY=your_toss_client_key
TOSS_PAYMENTS_SECRET_KEY=your_toss_secret_key
