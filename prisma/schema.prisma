// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  engineType = "library"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model MonthlyBestseller {
  id            Int      @id @default(autoincrement())
  snapshotMonth String   // YYYY-MM format
  rank          Int
  isbn13        String
  title         String
  author        String
  publisher     String
  coverUrl      String
  categoryName  String?
  description   String?
  link          String?
  source        String   @default("aladin")
  createdAt     DateTime @default(now())

  @@unique([snapshotMonth, isbn13])
  @@index([snapshotMonth, rank])
}

model Book {
  id          String   @id @default(uuid())
  title       String
  author      String
  category    String
  description String
  summary     String?  // LLM summary
  recommendation String? // AI Recommendation Reason
  imageUrl    String?  // Cover image URL
  purchaseLink String?
  isChoice    Boolean  @default(false) // curated for "BookFit Choice"
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  curations   Curation[] // Relation to Curation
  shelves     UserBookShelf[] // W4 — user library entries
}

model Curation {
  id          String   @id @default(uuid())
  theme       String   // e.g. "직장생활에 지친 당신에게"
  title       String   // specific catchphrase generated by AI
  description String   // Intro text for the collection
  books       Book[]   // Relation to Book model

  // Instagram Content
  instaCaption String? // Generated caption with hashtags
  cardImageUrl String? // URL of generated image

  // W2 — Magazine fields (nullable to preserve back-compat)
  slug        String?   @unique             // URL slug for /curation/[slug]
  category    String?                       // "감정", "계절", "직군", "트렌드" 등
  curatorNote String?                       // 큐레이터(=운영자) 한 단락 코멘트
  seoTitle    String?                       // SEO meta title
  seoDesc     String?                       // SEO meta description
  ogImage     String?                       // Custom OG image url
  readingTime Int?                          // 추정 읽는 시간 (분)
  publishedAt DateTime?
  status      String    @default("draft")   // draft | published
  viewCount   Int       @default(0)
  isFeatured  Boolean   @default(false)     // 홈 노출용

  isPublished Boolean  @default(false)      // legacy — W3에서 status로 통합 예정
  createdAt   DateTime @default(now())
}

model Letter {
  id              String   @id @default(uuid())
  title           String
  slug            String   @unique
  publishedAt     DateTime?
  status          String   @default("draft") // draft, published
  source          String   @default("google_books")
  googleVolumeId  String?
  isbn13          String?
  authors         String?
  publisher       String?
  publishedDate   String?
  categories      String?
  coverImageUrl   String?
  headlineTitle   String?
  metaTitle       String?
  metaDescription String?
  contentMarkdown String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  tags            String?
  readingTime     Int?
  ogImageUrl      String?
  seoKeywords     String?
}

model TemplateRequest {
  id        String   @id @default(uuid())
  name      String
  email     String
  status    String   @default("pending") // pending, sent
  createdAt DateTime @default(now())
}

model PageContent {
  id        String   @id // ex: "template-intro"
  content   String   // Storing HTML from WYSIWYG
  updatedAt DateTime @updatedAt
}

// W4 — User Retention models
model UserBookShelf {
  id        String   @id @default(uuid())
  userId    String   // Firebase uid
  bookId    String
  status    String   // "want" | "reading" | "done"
  rating    Int?     // 1~5
  oneLiner  String?  // 한줄 리뷰 (본인 노출 only at v1)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  book      Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([userId, status])
}

model EmailDispatchLog {
  id           String   @id @default(uuid())
  type         String   // "letter" | "curation"
  targetId     String   // letter.id or curation.id
  sentCount    Int      @default(0)
  errorMessage String?
  sentAt       DateTime @default(now())

  @@index([type, targetId])
}

model PersonalRecommendCache {
  id          String   @id @default(uuid())
  userId      String
  fingerprint String   // hash of user's bookmark set
  payload     String   // JSON serialized recommendation list
  expiresAt   DateTime
  createdAt   DateTime @default(now())

  @@unique([userId, fingerprint])
  @@index([userId])
}
